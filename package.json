{
  "name": "portfolio",
  "private": true,
  "version": "0.5.7",
  "type": "module",
  "scripts": {
    "clean": "vite:clean",
    "dev": "vite",
    "weigh:js": "gzip -c dist/assets/*.js | wc -c",
    "weigh:css": "gzip -c dist/assets/*.css | wc -c",
    "build": "vite build --base=./",
    "lint": "eslint --fix .",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:webkit:docker:build": "docker build -f ./test/integration/webkit/Dockerfile.webkit -t oc-webkit .",
    "test:webkit:docker:inspect": "./test/integration/webkit/inspect-webkit.sh",
    "test:webkit:docker:run": "docker run --rm --shm-size=1g -e BROWSER=webkit --tmpfs /tmp oc-webkit",
    "test:webkit:ci": "yarn test:webkit:docker:build && yarn test:webkit:docker:inspect && test:webkit:docker:run",
    "pw:install": "yarn playwright install && yarn playwright install-deps",
    "test:e2e": "playwright test test/accessibility",
    "test:perf": "playwright test test/performance --config=playwright.perf.config.ts",
    "preview": "vite preview",
    "predeploy": "yarn build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint": "^9.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "packageManager": "yarn@4.14.1",
  "homepage": "https://ericdev1o.github.io/OC900_p12_portfolio"
}
